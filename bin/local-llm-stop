#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
LIBEXEC_DIR="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

if [[ "${1-}" == "--help" || "${1-}" == "-h" ]]; then
  cat <<'USAGE'
Usage: local-llm-stop [ARGS...]

Stops the local AI stack by invoking:
  Stop AI.command

Any additional ARGS are forwarded to the underlying script.
USAGE
  exit 0
fi

exec /bin/bash "$LIBEXEC_DIR/Stop AI.command" "$@"
