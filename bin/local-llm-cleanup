#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${LOCAL_LLM_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/local-llm}"
STATE_FILE="${STATE_DIR}/terminal_window_ids.tmp"
LEGACY_STATE_FILES=(
  "/tmp/local_llm_terminal_window_ids.tmp"
  "/tmp/terminal_window_ids.tmp"
)

REMOVE_CONTAINER=0
REMOVE_VOLUME=0

if [[ "${1-}" == "--help" || "${1-}" == "-h" ]]; then
  cat <<'USAGE'
Usage: local-llm-cleanup [--remove-container] [--remove-volume]

Removes local state artifacts created by local-llm-start/stop.

Options:
  --remove-container  Also remove open-webui container if Docker is reachable.
  --remove-volume     Also remove open-webui Docker volume (implies --remove-container).
  -h, --help          Show this help.
USAGE
  exit 0
fi

while (($#)); do
  case "$1" in
    --remove-container)
      REMOVE_CONTAINER=1
      ;;
    --remove-volume)
      REMOVE_CONTAINER=1
      REMOVE_VOLUME=1
      ;;
    *)
      echo "Error: unknown argument: $1" >&2
      exit 2
      ;;
  esac
  shift
done

if [[ -f "${STATE_FILE}" ]]; then
  rm -f "${STATE_FILE}"
  echo "Removed state file: ${STATE_FILE}"
else
  echo "No state file to remove: ${STATE_FILE}"
fi

for legacy_file in "${LEGACY_STATE_FILES[@]}"; do
  if [[ -f "${legacy_file}" ]]; then
    rm -f "${legacy_file}"
    echo "Removed legacy state file: ${legacy_file}"
  fi
done

if [[ "${REMOVE_CONTAINER}" -eq 1 ]]; then
  if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
    docker rm -f open-webui >/dev/null 2>&1 || true
    echo "Removed container: open-webui (if present)"
    if [[ "${REMOVE_VOLUME}" -eq 1 ]]; then
      docker volume rm open-webui >/dev/null 2>&1 || true
      echo "Removed volume: open-webui (if present)"
    fi
  else
    echo "Docker unavailable; skipped container cleanup."
  fi
fi
